{
  "name": "ledger-cpa",
  "version": "1.0.0",
  "description": "Ledger — CPA Study Tracker",
  "scripts": {
    "build": "echo 'Static site — no build step needed'",
    "deploy": "npx vercel deploy --prod --yes",
    "deploy:rules": "npx firebase-tools deploy --only firestore:rules,firestore:indexes",
    "cap:ios": "npx cap sync ios && npx cap open ios",
    "cap:android": "npx cap sync android && npx cap open android",
    "cap:sync": "npx cap sync",
    "cap:copy": "npx cap copy"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "firebase-admin": "^12.7.0",
    "stripe": "^14.25.0"
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/ios": "^6.0.0"
  }
}
