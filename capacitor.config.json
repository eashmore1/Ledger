{
  "appId": "com.ledgercpa.app",
  "appName": "Ledger",
  "webDir": "www",
  "server": {
    "androidScheme": "https"
  },
  "ios": {
    "contentInset": "automatic",
    "backgroundColor": "#0a0618",
    "limitsNavigationsToAppBoundDomains": true
  },
  "android": {
    "backgroundColor": "#0a0618"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#0a0618",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0a0618"
    }
  }
}
