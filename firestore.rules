rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── USER PROFILES ──────────────────────────────────────────────────
    // Public read for all authenticated users, self-write only
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Follower edges: anyone can read (for counts/lists); you may only create/delete
      // the edge keyed by your OWN uid (i.e. you follow/unfollow as yourself).
      match /followers/{followerId} {
        allow read: if request.auth != null;
        // You may write the edge for yourself (you follow someone), OR the profile owner
        // may write edges under their own profile (approving a private follow request).
        allow write: if request.auth != null &&
          (request.auth.uid == followerId || request.auth.uid == userId);
      }

      // Feed PROPS (likes) on this user's activities — anyone reads; you may only
      // create/delete a prop attributed to your own uid.
      match /props/{propId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.resource.data.reactor == request.auth.uid;
        allow delete: if request.auth != null && resource.data.reactor == request.auth.uid;
      }

      // Feed COMMENTS on this user's activities — anyone reads; you may only
      // create/delete a comment attributed to your own uid.
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.resource.data.from == request.auth.uid;
        allow delete: if request.auth != null && resource.data.from == request.auth.uid;
      }

      // Referrals: a new user records themselves under the inviter's profile (doc id = their uid),
      // so the inviter can count referrals and earn rewards.
      match /referrals/{referredId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == referredId;
      }
    }

    // ── USER STATE ─────────────────────────────────────────────────────
    // Private — only the owning user can read/write
    match /userState/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── DIRECT MESSAGE CONVERSATIONS ───────────────────────────────────
    // Conversation ID is deterministic: sorted(uid1, uid2).join('__dm__')
    // Any authenticated user can create/read/update conversations they participate in.
    // We allow any auth'd user to create so either side can initiate.
    match /conversations/{convId} {
      allow read, update: if request.auth != null &&
        request.auth.uid in resource.data.participants;
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants;

      match /messages/{msgId} {
        // Read: must be a participant of the parent conversation
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        // Create: sender must match the from field
        allow create: if request.auth != null &&
          request.resource.data.from == request.auth.uid;
        // Delete: only the original sender can delete their own message
        allow delete: if request.auth != null &&
          resource.data.from == request.auth.uid;
      }
    }

    // ── STUDY CLUBS ────────────────────────────────────────────────────
    // Public clubs are readable by all authenticated users.
    // Any authenticated user can join (write to their own member doc).
    match /clubs/{clubId} {
      allow read: if request.auth != null;
      // Allow create/update so users can join and update club metadata
      allow create, update: if request.auth != null;

      match /messages/{msgId} {
        allow read: if request.auth != null;
        // Only the sender can create a message with their own UID
        allow create: if request.auth != null &&
          request.resource.data.from == request.auth.uid;
        // Only the original sender can delete their own message
        allow delete: if request.auth != null &&
          resource.data.from == request.auth.uid;
      }

      match /members/{userId} {
        allow read: if request.auth != null;
        // Users can only write their own membership record
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Live "studying now" presence — anyone reads; you write only your own presence doc.
      match /presence/{uid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

  }
}
