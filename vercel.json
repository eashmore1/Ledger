{
  "buildCommand": "echo 'static site'",
  "installCommand": "echo 'no install'",
  "cleanUrls": true,
  "trailingSlash": false,
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/login", "destination": "/index.html" },
    { "source": "/signup", "destination": "/index.html" },
    { "source": "/messages", "destination": "/index.html" },
    { "source": "/club/:id", "destination": "/index.html" },
    { "source": "/user/:id", "destination": "/index.html" },
    { "source": "/activity/:id", "destination": "/index.html" }
  ]
}
